# Database
DB_USERNAME=postgres
DB_PASSWORD=change_me

# JWT
JWT_SECRET=generate_a_random_64_char_secret_here_replace_this_with_actual_secret

# Video Sign (独立于 JWT_SECRET，必须不同)
VIDEO_SIGN_SECRET=another_random_64_char_secret_here_replace_this_with_actual_secret

# Redis (生产环境建议设置密码)
REDIS_PASSWORD=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:80,http://127.0.0.1:80

# AI: DeepSeek 讲述稿生成（不配置时 AI 生成功能返回明确提示）
DEEPSEEK_API_KEY=

# 互动课程插件
PLUGIN_INTERACTIVE_ENABLED=true
SLIDES_STORAGE_PATH=uploads/slides
