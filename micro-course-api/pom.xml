<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.2.12</version>
        <relativePath/>
        <!-- ⚠️ Spring Boot 3.2.12 EOL: 2026-11-18. Migrate to 3.4.x or 3.5.x before production -->
    </parent>

    <groupId>com.microcourse</groupId>
    <artifactId>micro-course-api</artifactId>
    <version>1.0.0</version>
    <packaging>jar</packaging>
    <name>micro-course-api</name>
    <description>微课管理平台后端 API</description>

    <properties>
        <java.version>17</java.version>
        <mybatis-plus.version>3.5.6</mybatis-plus.version>
        <jjwt.version>0.12.6</jjwt.version>
        <springdoc.version>2.5.0</springdoc.version>
        <flyway.version>10.20.1</flyway.version>
        <lombok.version>1.18.36</lombok.version>
        <!-- P0 CVE 修复：覆盖 Spring Boot BOM 管理的传递依赖版本 -->
        <tomcat.version>10.1.55</tomcat.version>
        <postgresql.version>42.7.11</postgresql.version>
        <!-- Phase K: 解除 P3-10 quarantine 隔离 — VideoP0ConcurrencyTest / VideoUploadP0ErrorTest
             种子数据修复后已能稳定 PASS,默认纳入 CI 运行。
             如未来再有损坏测试,临时用 `@Tag("quarantine")` + `mvn test -Dquarantine=true` 仍可恢复隔离。 -->
        <surefire.excludedGroups></surefire.excludedGroups>
    </properties>

    <dependencies>
        <!-- Spring Boot Web -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.retry</groupId>
            <artifactId>spring-retry</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework</groupId>
            <artifactId>spring-aspects</artifactId>
        </dependency>
        <!-- Spring Boot Validation -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-validation</artifactId>
        </dependency>

        <!-- P3-14 DB 连接池监控：Actuator 端点 + Micrometer Prometheus registry -->
        <!-- Actuator 暴露 /actuator/prometheus；micrometer 自动绑定 HikariCP/JVM/HTTP 指标 -->
        <!-- HikariCP hikaricp_connections_* 指标由 Spring Boot DataSourcePoolMetricsAutoConfiguration 自动注入，无需手写 metric-registry -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-actuator</artifactId>
        </dependency>
        <dependency>
            <groupId>io.micrometer</groupId>
            <artifactId>micrometer-registry-prometheus</artifactId>
        </dependency>

        <!-- MyBatis-Plus -->
        <dependency>
            <groupId>com.baomidou</groupId>
            <artifactId>mybatis-plus-spring-boot3-starter</artifactId>
            <version>${mybatis-plus.version}</version>
        </dependency>

        <!-- PostgreSQL -->
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <scope>runtime</scope>
        </dependency>

        <!-- Flyway：数据库 migration -->
        <dependency>
            <groupId>org.flywaydb</groupId>
            <artifactId>flyway-core</artifactId>
            <version>${flyway.version}</version>
        </dependency>
        <dependency>
            <groupId>org.flywaydb</groupId>
            <artifactId>flyway-database-postgresql</artifactId>
            <version>${flyway.version}</version>
            <scope>runtime</scope>
        </dependency>

        <!-- Spring Data Redis：登录失败计数 + Token 黑名单（Lettuce 客户端，Spring Boot 3.x 默认） -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-redis</artifactId>
        </dependency>

        <!-- Lettuce 连接池依赖（commons-pool2）：启用 lettuce.pool.* 必须显式引入 -->
        <dependency>
            <groupId>org.apache.commons</groupId>
            <artifactId>commons-pool2</artifactId>
        </dependency>

        <!-- JWT -->
        <dependency>
            <groupId>io.jsonwebtoken</groupId>
            <artifactId>jjwt-api</artifactId>
            <version>${jjwt.version}</version>
        </dependency>
        <dependency>
            <groupId>io.jsonwebtoken</groupId>
            <artifactId>jjwt-impl</artifactId>
            <version>${jjwt.version}</version>
            <scope>runtime</scope>
        </dependency>
        <dependency>
            <groupId>io.jsonwebtoken</groupId>
            <artifactId>jjwt-jackson</artifactId>
            <version>${jjwt.version}</version>
            <scope>runtime</scope>
        </dependency>

        <!-- OpenPDF：证书 PDF 生成（LGPL, JDK 17 兼容） -->
        <dependency>
            <groupId>com.github.librepdf</groupId>
            <artifactId>openpdf</artifactId>
            <version>1.3.39</version>
        </dependency>

        <!-- Lombok（⚠️ 仅运行时依赖，禁止添加 annotationProcessorPaths） -->
        <!-- 原因：JDK 17.0.18 (Homebrew) 与 Lombok 注解处理器冲突，导致 com.sun.tools.javac.code.TypeTag UNKNOWN -->
        <!-- 结论：本项目禁用 @Data/@Getter/@Setter/@RequiredArgsConstructor/@Slf4j 等 Lombok 注解 -->
        <!-- 所有 DTO/Entity 必须手写 getter/setter；注入使用 @Autowired 替换 @RequiredArgsConstructor -->
        <!-- 参见复查/根因报告-Lombok冲突.md -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <optional>true</optional>
        </dependency>

        <!-- Spring Boot Security -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-security</artifactId>
        </dependency>

        <!-- CAS (stub only, spring-security-cas 在 Spring Boot 3.x 已被移除,实际未使用) -->
        

        <!-- Hutool -->
        <dependency>
            <groupId>cn.hutool</groupId>
            <artifactId>hutool-all</artifactId>
            <version>5.8.46</version>
        </dependency>

        <!-- EasyExcel -->
        <dependency>
            <groupId>com.alibaba</groupId>
            <artifactId>easyexcel</artifactId>
            <version>3.3.4</version>
            <exclusions>
                <!-- 排除所有 POI 传递依赖，使用项目显式声明的 poi-ooxml:5.3.0 -->
                <exclusion>
                    <groupId>org.apache.poi</groupId>
                    <artifactId>poi</artifactId>
                </exclusion>
                <exclusion>
                    <groupId>org.apache.poi</groupId>
                    <artifactId>poi-ooxml</artifactId>
                </exclusion>
                <exclusion>
                    <groupId>org.apache.poi</groupId>
                    <artifactId>poi-ooxml-full</artifactId>
                </exclusion>
                <exclusion>
                    <groupId>org.apache.poi</groupId>
                    <artifactId>poi-ooxml-schemas</artifactId>
                </exclusion>
            </exclusions>
        </dependency>

        <!-- Apache POI - PPTX 解析与渲染 -->
        <!-- poi-ooxml 含 XSLF 类(XMLSlideShow/XSLFTextRun等)，poi-ooxml-full 仅含额外 schema -->
        <dependency>
            <groupId>org.apache.poi</groupId>
            <artifactId>poi-ooxml</artifactId>
            <version>5.3.1</version>
        </dependency>
        <dependency>
            <groupId>org.apache.poi</groupId>
            <artifactId>poi-ooxml-full</artifactId>
            <version>5.3.1</version>
        </dependency>

        <!-- Jsoup: HTML sanitization (XSS prevention) -->
        <dependency>
            <groupId>org.jsoup</groupId>
            <artifactId>jsoup</artifactId>
            <version>1.18.3</version>
        </dependency>

        <!-- JAXB (Java 9+ 移除，POI 需要 javax.xml.bind) -->
        <dependency>
            <groupId>javax.xml.bind</groupId>
            <artifactId>jaxb-api</artifactId>
            <version>2.3.1</version>
        </dependency>
        <dependency>
            <groupId>org.glassfish.jaxb</groupId>
            <artifactId>jaxb-runtime</artifactId>
            <version>2.3.8</version>
        </dependency>

        <!-- SpringDoc OpenAPI -->
        <dependency>
            <groupId>org.springdoc</groupId>
            <artifactId>springdoc-openapi-starter-webmvc-ui</artifactId>
            <version>${springdoc.version}</version>
        </dependency>

        <!-- Logstash Logback Encoder (JSON structured logging) -->
        <dependency>
            <groupId>net.logstash.logback</groupId>
            <artifactId>logstash-logback-encoder</artifactId>
            <version>7.4</version>
        </dependency>

        <!-- Spring Boot Test -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Spring Security Test -->
        <dependency>
            <groupId>org.springframework.security</groupId>
            <artifactId>spring-security-test</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- H2 Database for Testing -->
        <dependency>
            <groupId>com.h2database</groupId>
            <artifactId>h2</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- P3-10 quarantine 机制：surefire 默认排除 @Tag("quarantine") 测试。 -->
            <!-- version 由 spring-boot-starter-parent 3.2.12 统一管理（不引入新依赖）。 -->
            <!-- excludedGroups 绑定 ${surefire.excludedGroups}（默认 quarantine）； -->
            <!-- `-Dquarantine=true` 激活 quarantine profile 后该属性清空，从而纳入运行。 -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <excludedGroups>${surefire.excludedGroups}</excludedGroups>
                    <argLine>-Dnet.bytebuddy.experimental=true</argLine>
                    <!-- CI 慢根因修复尝试(agent 报告 P0-1):
                         后端 246 测试串行 ~50s,CI 慢 3-5x.
                         ★ 纪律 2 警示: 开启 <parallel>classes</parallel> 后
                         AuthFlowIntegrationTest.refreshToken_IssuesNewJwt 失败
                         (Redis 锁被其他并行 test 覆盖 → 401 vs 200).
                         共享 Redis + 共享 DB 的 integration test 套件不适合 classes 级别并行.
                         改用 methods 级别并行(同一 class 内方法并行,跨 class 串行)
                         可以部分提速且不破坏 fixture 隔离 -->
                    <forkCount>1</forkCount>
                    <reuseForks>true</reuseForks>
                </configuration>
            </plugin>

            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <configuration>
                    <excludes>
                        <exclude>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                        </exclude>
                    </excludes>
                    <jvmArguments>
                        --enable-native-access=ALL-UNNAMED
                    </jvmArguments>
                </configuration>
            </plugin>

            <!-- P3-1（Phase C-3）：JaCoCo 覆盖率门禁 -->
            <!-- prepare-agent 在 test 阶段前注入探针；report 生成 target/site/jacoco/index.html -->
            <!-- check 在 verify 阶段强制 LINE 覆盖率 ≥ 10%（保守起步，避免立即挂红） -->
            <!-- 当前覆盖率估算 ~13%（94 测试 / 382 类）；Phase D 收紧到 30%，长期 50% -->
            <!-- 注意：jacoco 不涉及 annotation processor，与本项目 Lombok 禁用约束不冲突 -->
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <version>0.8.14</version>
                <executions>
                    <execution>
                        <goals>
                            <goal>prepare-agent</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>report</id>
                        <phase>test</phase>
                        <goals>
                            <goal>report</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>check</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>check</goal>
                        </goals>
                        <configuration>
                            <rules>
                                <rule>
                                    <element>BUNDLE</element>
                                    <limits>
                                        <limit>
                                            <counter>LINE</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>0.10</minimum>
                                        </limit>
                                    </limits>
                                 </rule>
                            </rules>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <!-- P3-10 quarantine 机制：`-Dquarantine=true` 激活本 profile，清空 surefire.excludedGroups， -->
    <!-- 从而把 @Tag("quarantine") 的损坏测试纳入运行（用于每周回归 / 修复排查）。 -->
    <!-- 注意：被 quarantine 的测试当前已知 ERROR，启用后预期失败——这正是 quarantine 的提醒语义。 -->
    <profiles>
        <profile>
            <id>quarantine</id>
            <activation>
                <property>
                    <name>quarantine</name>
                    <value>true</value>
                </property>
            </activation>
            <properties>
                <!-- 清空排除组：纳入 quarantine 测试一起运行 -->
                <surefire.excludedGroups></surefire.excludedGroups>
            </properties>
        </profile>
    </profiles>
</project>