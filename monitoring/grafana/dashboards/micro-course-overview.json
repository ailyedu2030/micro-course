{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "title": "API 响应时间 (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"micro-course-api\"}[5m])) by (le, uri))",
          "legendFormat": "p50 {{uri}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"micro-course-api\"}[5m])) by (le, uri))",
          "legendFormat": "p95 {{uri}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"micro-course-api\"}[5m])) by (le, uri))",
          "legendFormat": "p99 {{uri}}",
          "refId": "C"
        }
      ]
    },
    {
      "title": "QPS (每秒请求数)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"micro-course-api\"}[1m])) by (uri)",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "HTTP 状态码分布",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"micro-course-api\"}[5m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "HikariCP 连接池",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=\"micro-course-api\"}",
          "legendFormat": "active",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_idle{job=\"micro-course-api\"}",
          "legendFormat": "idle",
          "refId": "B"
        },
        {
          "expr": "hikaricp_connections_pending{job=\"micro-course-api\"}",
          "legendFormat": "pending",
          "refId": "C"
        }
      ]
    },
    {
      "title": "JVM 堆内存",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{job=\"micro-course-api\", area=\"heap\"}) by (instance)",
          "legendFormat": "used {{instance}}",
          "refId": "A"
        },
        {
          "expr": "sum(jvm_memory_max_bytes{job=\"micro-course-api\", area=\"heap\"}) by (instance)",
          "legendFormat": "max {{instance}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "PostgreSQL 慢查询 (active)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "active connections",
          "refId": "A"
        },
        {
          "expr": "pg_stat_activity_max_tx_duration",
          "legendFormat": "max tx duration (s)",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "title": "微课平台 总览仪表盘 (W31 治理)",
  "uid": "micro-course-overview"
}